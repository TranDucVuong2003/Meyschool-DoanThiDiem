# =============================================
# .htaccess - Doan Thi Diem Website
# =============================================

Options -Indexes

# Bảo vệ thư mục config/ - không cho truy cập trực tiếp
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Chặn truy cập trực tiếp vào config/
    RewriteRule ^config/ - [F,L]

    # Chặn truy cập trực tiếp vào .git/
    RewriteRule ^\.git/ - [F,L]
</IfModule>

# Bảo mật header
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Chặn truy cập file nhạy cảm
<FilesMatch "\.(env|git|gitignore|htpasswd|bak|log|sql)$">
    Require all denied
</FilesMatch>

# Giới hạn kích thước upload (10MB)
LimitRequestBody 10485760
